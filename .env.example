# Copy to .env.local and fill in your Atlas user/password.
# Use database name nadee-textile in the path (before ?).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/nadee-textile?retryWrites=true&w=majority&appName=YourAppName

# NextAuth / Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Google Cloud Storage
PROJECT_ID=your-gcp-project-id
BUCKET_NAME=your-public-bucket-name
#
# --- GOOGLE_CLOUD_KEY_FILE (path to service account JSON) ---
#
# Local (`npm run dev` / `next dev`): relative to project root OR absolute path
#   GOOGLE_CLOUD_KEY_FILE=src/lib/amplified-vine-462115-g9-2cc994038afc.json
#
# Production Docker / Cloud Run (this repo’s Dockerfile copies the key to a fixed path):
#   GOOGLE_CLOUD_KEY_FILE=/app/credentials/gcs-sa.json
#   Set this in Cloud Run → Service → Edit & deploy new revision → Variables & secrets.
#   The file must exist in the image (build must include your JSON; see Dockerfile + postbuild).
#
# Production without a key file in the image (recommended for GitHub → Cloud Build):
#   Do NOT set GOOGLE_CLOUD_KEY_FILE (delete the var if it was set).
#   Grant the Cloud Run *runtime* service account Storage Object Admin (or similar) on BUCKET_NAME.
#   Only PROJECT_ID + BUCKET_NAME are required; the app uses Application Default Credentials.
#
# Alternative: full JSON in an env var (Secret Manager → env):
#   GOOGLE_CLOUD_CREDENTIALS_JSON={"type":"service_account",...}
#   (If set, GOOGLE_CLOUD_KEY_FILE is ignored.)
#
# Also supported: GOOGLE_APPLICATION_CREDENTIALS=/absolute/path.json

# Optional overrides for npm run seed (defaults shown in seed output)
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_USER_EMAIL=
# SEED_USER_PASSWORD=
