# Copy to .env.local and fill in your Atlas user/password.
# Use database name nadee-textile in the path (before ?).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/nadee-textile?retryWrites=true&w=majority&appName=YourAppName

# NextAuth / Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Google Cloud Storage
PROJECT_ID=your-gcp-project-id
BUCKET_NAME=your-public-bucket-name
#
# Production (Cloud Run / Docker): .env files are not in the image. Prefer one of:
#
# A) Secret Manager → expose as env var (recommended if not using bucket IAM + runtime SA):
#    GOOGLE_CLOUD_CREDENTIALS_JSON = full service account JSON (single line or normal JSON)
#
# B) Cloud Run service account + bucket IAM (no JSON in env):
#    Grant the Cloud Run runtime SA "Storage Object Admin" (or create/upload) on the bucket.
#    Leave GOOGLE_CLOUD_KEY_FILE unset; set PROJECT_ID + BUCKET_NAME only.
#
# Local dev: path relative to project root (file is gitignored; keep out of git)
# GOOGLE_CLOUD_KEY_FILE=src/lib/amplified-vine-462115-g9-2cc994038afc.json
#
# Docker / Cloud Run when the image includes credentials/gcs-sa.json (see Dockerfile):
# GOOGLE_CLOUD_KEY_FILE=/app/credentials/gcs-sa.json
#
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path.json  # also supported locally

# Optional overrides for npm run seed (defaults shown in seed output)
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_USER_EMAIL=
# SEED_USER_PASSWORD=
