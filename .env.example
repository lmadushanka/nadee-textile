# Copy to .env.local and fill in your Atlas user/password.
# Use database name nadee-textile in the path (before ?).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/nadee-textile?retryWrites=true&w=majority&appName=YourAppName

# NextAuth / Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Google Cloud Storage
PROJECT_ID=your-gcp-project-id
BUCKET_NAME=your-public-bucket-name
# Path to service account file (relative to project root or absolute path)
GOOGLE_CLOUD_KEY_FILE=path/to/service-account.json
# Optional: paste service account JSON as one line (if not using ADC file)
# GOOGLE_CLOUD_CREDENTIALS_JSON={"type":"service_account",...}

# Optional overrides for npm run seed (defaults shown in seed output)
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_USER_EMAIL=
# SEED_USER_PASSWORD=
